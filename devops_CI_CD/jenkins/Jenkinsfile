pipeline {
    agent any

    options {
        timestamps()
        skipDefaultCheckout(true)
    }

    environment {
        AWS_REGION   = 'us-east-1'
        SCRIPTS_PATH = 'devops_CI_CD/scripts'
        ANSIBLE_PATH = 'devops_CI_CD/ansible'
    }

    stages {
        stage('Sparse Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    userRemoteConfigs: scm.userRemoteConfigs,
                    branches: scm.branches,
                    extensions: [
                        [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
                            [$class: 'SparseCheckoutPath', path: "${env.SCRIPTS_PATH}"],
                            [$class: 'SparseCheckoutPath', path: "${env.ANSIBLE_PATH}"]
                        ]]
                    ]
                ])
            }
        }

        stage('Bootstrap EC2 Agent') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials'
                ]]) {
                    dir(env.SCRIPTS_PATH) {
                        sh 'bash ./ec2_container_setup.sh'
                    }
                }
            }
        }

        stage('Load Ephemeral Agent Env') {
            steps {
                dir(env.SCRIPTS_PATH) {
                    script {
                        def props = readProperties file: 'ephem_env.txt'
                        env.AGENT_ID = props.AGENT_INSTANCE_ID
                        env.AGENT_IP = props.AGENT_IP
                        echo "Loaded AGENT_ID=${env.AGENT_ID}"
                    }
                }
            }
        }

        stage('Run Ansible Playbook via SSM') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials'
                ]]) {
                    script {
                        def ansibleCmd = 'sudo docker exec jenkins-agent bash -lc "ansible-playbook -i inventory/hosts playbook.yml -e ansible_host=localhost"'
                        def jsonCmd    = "'commands=[\"${ansibleCmd.replace('\"','\\\"')}\"]'"

                        sh """
                        aws ssm send-command \\
                          --region ${env.AWS_REGION} \\
                          --instance-ids ${env.AGENT_ID} \\
                          --document-name "AWS-RunShellScript" \\
                          --comment "Run Ansible inside container" \\
                          --parameters ${jsonCmd} \\
                          --query "Command.CommandId" --output text
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
