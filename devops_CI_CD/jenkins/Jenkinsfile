pipeline {
    agent any

    environment {
        AWS_REGION = 'us-east-1'
        INSTANCE_ID = 'i-0123456789abcdef0' // Reemplaza con tu ID de instancia EC2
        CONTAINER_NAME = 'jenkins-agent'
    }

    stages {
        stage('Ejecutar Ansible en contenedor Docker vía SSM') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                    sh '''
                        echo "[INFO] Enviando comando SSM para ejecutar Ansible en contenedor Docker..."
                        COMMAND_ID=$(aws ssm send-command \
                            --region "$AWS_REGION" \
                            --instance-ids "$INSTANCE_ID" \
                            --document-name "AWS-RunShellScript" \
                            --comment "Ejecutar Ansible en contenedor Docker" \
                            --parameters commands='[
                                "echo Iniciando ejecución de Ansible en contenedor...",
                                "sudo docker exec $CONTAINER_NAME bash -c \\'ansible-playbook -i inventory/hosts playbook.yml\\'"
                            ]' \
                            --query "Command.CommandId" \
                            --output text)

                        echo "[INFO] Comando SSM enviado. Command ID: $COMMAND_ID"

                        echo "[INFO] Esperando a que el comando SSM se complete..."
                        aws ssm wait command-executed --command-id "$COMMAND_ID" --instance-id "$INSTANCE_ID" --region "$AWS_REGION"

                        echo "[INFO] Recuperando salida del comando SSM..."
                        aws ssm get-command-invocation --command-id "$COMMAND_ID" --instance-id "$INSTANCE_ID" --region "$AWS_REGION"
                    '''
                }
            }
        }
    }
}
