pipeline {
    agent any

    options {
        timestamps()
        skipDefaultCheckout(true)
    }

    environment {
        AWS_REGION   = 'us-east-1'
        SCRIPTS_PATH = 'devops_CI_CD/scripts'
        ANSIBLE_PATH = 'devops_CI_CD/ansible'
    }

    stages {
        stage('Sparse Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    userRemoteConfigs: scm.userRemoteConfigs,
                    branches: scm.branches,
                    extensions: [
                        [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
                            [$class: 'SparseCheckoutPath', path: "${env.SCRIPTS_PATH}"],
                            [$class: 'SparseCheckoutPath', path: "${env.ANSIBLE_PATH}"]
                        ]]
                    ]
                ])
            }
        }

        stage('Bootstrap EC2 Agent') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials'
                ]]) {
                    dir(env.SCRIPTS_PATH) {
                        sh 'bash ./ec2_container_setup.sh'
                    }
                }
            }
        }

        stage('Load Ephemeral Agent Env') {
            steps {
                dir(env.SCRIPTS_PATH) {
                    script {
                        def props = readProperties file: 'ephem_env.txt'
                        withEnv(["AGENT_ID=${props.AGENT_ID}"]) {
                            echo "Loaded AGENT_ID=${env.AGENT_ID}"
                        }
                    }
                }
            }
        }

        stage('Run Ansible Playbook via SSM') {
            steps {
                withCredentials([[ 
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-credentials' 
                ]]) {
                    dir(env.SCRIPTS_PATH) {
                        sh '''
                          echo "[INFO] Running Ansible playbook inside container..."
                          COMMAND_ID=$(aws ssm send-command \
                            --region "$AWS_REGION" \
                            --instance-ids "$AGENT_INSTANCE_ID" \
                            --document-name "AWS-RunShellScript" \
                            --comment "Run Ansible playbook in container" \
                            --parameters commands="[
                              \\"echo 'Starting Ansible inside container'\\",
                              \\"sudo docker exec jenkins-agent bash -lc 'ansible-playbook -i inventory/hosts playbook.yml -e ansible_host=localhost'\\"  
                            ]" \
                            --query "Command.CommandId" \
                            --output text)

                          echo "[INFO] Sent SSM command, CommandId=$COMMAND_ID"
                        '''
                    }
                }
            }
        }

        stage('Wait for Ansible Playbook Completion') {
            steps {
                script {
                    def commandId = sh(script: 'aws ssm list-commands --query "Commands[?CommandId==`$COMMAND_ID`].Status" --output text', returnStdout: true).trim()
                    echo "Ansible playbook command status: ${commandId}"
                }
            }
        }

        stage('Cleanup') {
            steps {
                dir(env.SCRIPTS_PATH) {
                    sh 'bash ./cleanup.sh'
                }
            }
        }

    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
