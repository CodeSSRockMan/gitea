pipeline {
    agent any

    options {
        // Print timestamps in the console log
        timestamps()
        // Skip the default workspace checkout; we'll do a sparse checkout manually
        skipDefaultCheckout(true)
    }

    environment {
        AWS_REGION = 'us-east-1'
    }

    stages {
        stage('Sparse Checkout') {
            steps {
                // Only check out the scripts and ansible folders
                checkout([
                    $class: 'GitSCM',
                    userRemoteConfigs: scm.userRemoteConfigs,
                    branches: scm.branches,
                    extensions: [
                        [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
                            [$class: 'SparseCheckoutPath', path: 'devops_CI_CD/scripts'],
                            [$class: 'SparseCheckoutPath', path: 'ansible']
                        ]]
                    ]
                ])
            }
        }

        stage('Bootstrap EC2 Agent') {
            steps {
                dir('devops_CI_CD/scripts') {
                    // Make all bootstrap scripts executable
                    sh 'chmod +x 0[1-7]-*.sh'

                    // Run each module in order
                    sh './01-fetch-master.sh'
                    sh './02-sg-iam.sh'
                    sh './03-launch-agent.sh'
                    sh './04-docker-run.sh'
                    sh './05-health-check.sh'
                    sh './06-version-check.sh'
                    sh './07-export-env.sh'
                }
            }
        }

        stage('Load Ephemeral Agent Environment') {
            steps {
                dir('devops_CI_CD/scripts') {
                    script {
                        // Read key=value pairs from the file into env
                        def props = readProperties file: 'ephem_env.txt'
                        props.each { key, value -> env[key] = value }
                        echo "Loaded AGENT_ID=${env.AGENT_ID}, AGENT_IP=${env.AGENT_IP}"
                    }
                }
            }
        }

        stage('Run Ansible Playbook via SSM') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']
                ]) {
                    dir('ansible') {
                        sh '''
                            echo "AWS identity:"
                            aws sts get-caller-identity

                            echo "Running Ansible playbook against agent at $AGENT_IP"
                            source ../.venv/bin/activate

                            ANSIBLE_HOST_KEY_CHECKING=False \
                              ansible-playbook -i inventory/hosts playbook.yml \
                              -e "ansible_host=$AGENT_IP"
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
